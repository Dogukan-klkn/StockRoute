{
  "expo": {
    "name": "StockRoute",
    "slug": "stockroute",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "stockroute",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      }
    },
    "plugins": ["expo-router"]
  }
}
