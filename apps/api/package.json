    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@stockroute/config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.4",
