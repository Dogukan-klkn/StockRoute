# Compose, PostgreSQL'i host'ta 5433'e eşler (yerel 5432 ile çakışmasın).
# Docker içindeki api servisi bunun yerine `db:5432` kullanır.
DATABASE_URL=postgresql://stockroute:password@localhost:5433/stockroute
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d
API_PORT=3000
CORS_ORIGIN=http://localhost:5173
